        "format": "prettier --write src/**/*.js"
    },
    "devDependencies": {
        "@babel/cli": "^7.20.0",
        "@babel/core": "^7.20.0",
        "@babel/preset-env": "^7.20.0",
        "@babel/preset-react": "^7.18.0",
        "eslint": "^8.30.0",
        "eslint-plugin-react": "^7.31.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "jest": "^29.0.0",
        "prettier": "^2.8.0"
    },
    "browserslist": {
        "production": [
