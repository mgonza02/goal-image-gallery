        "index.js",
        "GoalImageGallery.js",
        "components/",
        "hooks/",
        "styles/",
        "utils/",
        "examples/",
        "README.md",
        "QUICK_REFERENCE.md",
        "MIGRATION.md",
        "IMPLEMENTATION_SUMMARY.md"
    ],
    "peerDependencies": {
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "@mui/material": "^5.0.0",
        "@mui/icons-material": "^5.0.0",
